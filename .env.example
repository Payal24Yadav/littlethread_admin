# Admin dashboard (Vite) env vars (example)
# Backend API base URL (include `/api`)
VITE_API_URL=http://localhost:8000/api

# Optional (only needed if you import/use `src/services/supabaseClient.js`)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_publishable_anon_key

